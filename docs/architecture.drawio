        <mxCell id="legend" value="&lt;b&gt;Edge legend&lt;/b&gt;&lt;br/&gt;&#160;&#160;&lt;span style=&#39;color:#000000&#39;&gt;━━&lt;/span&gt; topic&lt;br/&gt;&#160;&#160;&lt;span style=&#39;color:#C62828&#39;&gt;━━&lt;/span&gt; action&lt;br/&gt;&#160;&#160;&lt;span style=&#39;color:#1565C0&#39;&gt;━━&lt;/span&gt; service" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=12;rounded=1;fillColor=#FFFFFF;strokeColor=#888888;" vertex="1" parent="1"><mxGeometry x="20" y="20" width="220" height="100" as="geometry" /></mxCell>
        <mxCell id="cluster_arduino" value="arduino Twist ↔ serial bridge to the mecanum base; publishes wheel odometry." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#C68A1B;verticalAlign=top;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1269.9" y="286.0" width="444.3" height="146.0" as="geometry" /></mxCell>
        <mxCell id="cluster_vision" value="vision_processing_package Camera capture, YOLO inference, object selection, and bbox→XYZ mapping." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7F3FF;strokeColor=#1F6FB2;verticalAlign=top;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="8.0" y="286.0" width="1106.4" height="265.0" as="geometry" /></mxCell>
        <mxCell id="cluster_wskr" value="wskr Floor masking, whisker ranges, heading fusion, and the autopilot/approach pipeline." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E9F8EE;strokeColor=#2D8A4E;verticalAlign=top;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="18.5" y="8.0" width="2015.4" height="270.0" as="geometry" /></mxCell>
        <mxCell id="cluster_xarm" value="xarm_object_collector_package Single-owner xArm hardware node, GA-planned grasp pipeline, and Q-learning wrist policy." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4ECFB;strokeColor=#7A3FAE;verticalAlign=top;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="908.2" y="1151.0" width="685.0" height="347.0" as="geometry" /></mxCell>
        <mxCell id="cluster_sysmgr" value="system_manager_package FSM supervisor and search behavior — student-implemented in this project." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7E0;strokeColor=#A07A00;verticalAlign=top;fontStyle=1;fontSize=12;dashed=1;" vertex="1" parent="1"><mxGeometry x="447.1" y="701.0" width="664.4" height="146.0" as="geometry" /></mxCell>
        <mxCell id="cluster_util" value="utilities Foxglove WebSocket bridge, telemetry shims, and tuning GUIs." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F0F0;strokeColor=#666666;verticalAlign=top;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="351.9" y="855.0" width="397.8" height="503.0" as="geometry" /></mxCell>
        <mxCell id="n_arduino" value="&lt;b&gt;mecanum_serial_bridge&lt;/b&gt;&lt;br/&gt;Converts cmd_vel into Arduino V/X serial&lt;br/&gt;commands and integrates encoder deltas&lt;br/&gt;into nav_msgs/Odometry on /odom." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#34495E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1391.2" y="330.2" width="200.9" height="93.6" as="geometry" /></mxCell>
        <mxCell id="n_cam" value="&lt;b&gt;gstreamer_camera&lt;/b&gt;&lt;br/&gt;Pulls JPEG frames from the USB webcam&lt;br/&gt;via GStreamer and republishes them as&lt;br/&gt;CompressedImage on camera1/image_raw." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#34495E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="16.0" y="342.2" width="210.6" height="93.6" as="geometry" /></mxCell>
        <mxCell id="n_yolo" value="&lt;b&gt;vision_inference_service&lt;/b&gt;&lt;br/&gt;Runs YOLO + ByteTrack on every camera&lt;br/&gt;frame and serves on-demand detection,&lt;br/&gt;property, and rotated-AR queries." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#34495E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="446.8" y="377.2" width="206.8" height="93.6" as="geometry" /></mxCell>
        <mxCell id="n_sel" value="&lt;b&gt;object_selection_node&lt;/b&gt;&lt;br/&gt;Picks the best detection from the latest&lt;br/&gt;YOLO frame using a class-priority list." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#34495E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="913.1" y="449.2" width="193.3" height="93.6" as="geometry" /></mxCell>
        <mxCell id="n_xyz" value="&lt;b&gt;bbox_to_xyz_node&lt;/b&gt;&lt;br/&gt;Maps a 2D bounding-box center into&lt;br/&gt;arm-frame millimetres using calibration." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#34495E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="913.5" y="330.2" width="192.6" height="93.6" as="geometry" /></mxCell>
        <mxCell id="n_floor" value="&lt;b&gt;wskr_floor&lt;/b&gt;&lt;br/&gt;Builds a binary floor mask from the&lt;br/&gt;camera frame for use by whisker rays." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#34495E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="26.5" y="172.2" width="189.6" height="93.6" as="geometry" /></mxCell>
        <mxCell id="n_range" value="&lt;b&gt;wskr_range&lt;/b&gt;&lt;br/&gt;Marches 11 calibrated whisker rays over&lt;br/&gt;the floor mask and the tracked bbox to&lt;br/&gt;produce floor + target distance arrays." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#34495E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="451.7" y="129.2" width="197.1" height="93.6" as="geometry" /></mxCell>
        <mxCell id="n_dr" value="&lt;b&gt;wskr_dead_reckoning&lt;/b&gt;&lt;br/&gt;Fuses the latest visual heading with&lt;br/&gt;integrated yaw-rate from /odom and&lt;br/&gt;publishes mode + heading-to-target." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#34495E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1398.0" y="176.2" width="187.2" height="93.6" as="geometry" /></mxCell>
        <mxCell id="n_auto" value="&lt;b&gt;wskr_autopilot&lt;/b&gt;&lt;br/&gt;MLP that turns whisker fan + heading&lt;br/&gt;into a Twist on WSKR/cmd_vel." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#34495E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1838.7" y="136.2" width="187.2" height="93.6" as="geometry" /></mxCell>
        <mxCell id="n_approach" value="&lt;b&gt;wskr_approach_action&lt;/b&gt;&lt;br/&gt;ApproachObject server: ArUco/CSRT&lt;br/&gt;tracking, autopilot gating, and the&lt;br/&gt;per-frame ArUco marker publisher." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#34495E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="916.2" y="176.2" width="187.2" height="93.6" as="geometry" /></mxCell>
        <mxCell id="n_hw" value="&lt;b&gt;xarm_hardware_node&lt;/b&gt;&lt;br/&gt;Sole owner of the xArm USB device;&lt;br/&gt;exposes every controller method as a&lt;br/&gt;service plus a play_waypoints action." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#34495E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1398.0" y="1316.2" width="187.2" height="93.6" as="geometry" /></mxCell>
        <mxCell id="n_grasp" value="&lt;b&gt;grasping_commander_action_node&lt;/b&gt;&lt;br/&gt;XArm grasp action server: chains&lt;br/&gt;perception, Q-learning, GA planning,&lt;br/&gt;and arm-control service calls." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#34495E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="916.2" y="1218.2" width="187.2" height="93.6" as="geometry" /></mxCell>
        <mxCell id="n_q" value="&lt;b&gt;q_learning_wrist_node&lt;/b&gt;&lt;br/&gt;Looks up the best wrist angle for a&lt;br/&gt;given aspect ratio from a CSV policy." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#34495E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1398.0" y="1195.2" width="187.2" height="93.6" as="geometry" /></mxCell>
        <mxCell id="n_state" value="b&gt;state_manager_node&lt;/b&gt;&lt;br/&gt;FSM that drives one full collection&lt;br/&gt;cycle (search → select → approach →&lt;br/&gt;grasp → drop). &lt;b&gt;STUDENT TODO.&lt;/b" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE9A8;strokeColor=#A07A00;fontSize=10;" vertex="1" parent="1"><mxGeometry x="455.0" y="745.2" width="190.3" height="93.6" as="geometry" /></mxCell>
        <mxCell id="n_search" value="b&gt;search_supervisor&lt;/b&gt;&lt;br/&gt;WskrSearch action server: wanders&lt;br/&gt;while watching for toys / ArUco IDs.&lt;br/&gt;&lt;b&gt;STUDENT TODO.&lt;/b" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE9A8;strokeColor=#A07A00;fontSize=10;" vertex="1" parent="1"><mxGeometry x="916.2" y="745.2" width="187.2" height="93.6" as="geometry" /></mxCell>
        <mxCell id="n_fxbridge" value="&lt;b&gt;foxglove_bridge&lt;/b&gt;&lt;br/&gt;Streams ROS topics, params, and&lt;br/&gt;services to Foxglove Studio over a&lt;br/&gt;WebSocket on port 8765." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#34495E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="456.6" y="1256.2" width="187.2" height="93.6" as="geometry" /></mxCell>
        <mxCell id="n_apprbr" value="&lt;b&gt;wskr_foxglove_approach_bridge&lt;/b&gt;&lt;br/&gt;Wraps the WSKR/XArm actions as plain&lt;br/&gt;services so the Foxglove dashboard&lt;br/&gt;can dispatch them." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#34495E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="450.9" y="1018.2" width="198.6" height="93.6" as="geometry" /></mxCell>
        <mxCell id="n_webhelp" value="&lt;b&gt;wskr_web_helper&lt;/b&gt;&lt;br/&gt;Publishes one latched listing of the&lt;br/&gt;autopilot model files available on disk." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#34495E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="456.5" y="1137.2" width="187.4" height="93.6" as="geometry" /></mxCell>
        <mxCell id="n_throttle" value="&lt;b&gt;camera_throttle / overlay_throttle&lt;/b&gt;&lt;br/&gt;topic_tools republishers that drop image&lt;br/&gt;topics to dashboard-friendly rates." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#34495E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="452.8" y="899.2" width="194.8" height="93.6" as="geometry" /></mxCell>
